# EspoCRM Environment Variables
# Copy this file to .env and edit the passwords before starting services.
#
#   cp compose/.env.example compose/.env
#   # edit compose/.env with your passwords
#   make up

# MariaDB Configuration
MARIADB_ROOT_PASSWORD=change_this_root_password
MARIADB_DATABASE=espocrm
MARIADB_USER=espocrm
MARIADB_PASSWORD=change_this_db_password

# EspoCRM Configuration
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=change_this_admin_password
ESPOCRM_SITE_URL=http://localhost
ESPOCRM_WEBSOCKET_URL=ws://localhost/ws
