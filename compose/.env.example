# EspoCRM Environment Variables
# This file is auto-generated by 'make setup' from ansible vault secrets
# DO NOT EDIT THIS FILE DIRECTLY - Edit ansible/group_vars/all/vault.yml instead

# MariaDB Configuration
MARIADB_ROOT_PASSWORD=your_secure_root_password_here
MARIADB_DATABASE=espocrm
MARIADB_USER=espocrm
MARIADB_PASSWORD=your_secure_db_password_here

# EspoCRM Configuration
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=your_secure_admin_password_here
ESPOCRM_SITE_URL=http://localhost
ESPOCRM_WEBSOCKET_URL=ws://localhost/ws